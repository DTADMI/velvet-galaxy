#!/usr/bin/env bash
set -euo pipefail

pnpm lint
pnpm check:supabase-security
echo "[pre-commit] Running encoding checks..."
STAGED_ENCODING=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null | grep -E '\.(sql|md|ps1)
echo ""

pnpm build
pnpm test
 | tr '\n' ',' | sed 's/,$//')
if [ -n "$STAGED_ENCODING" ]; then
  powershell -NoProfile -Command "& ./scripts/check-encoding.ps1 -Files '$STAGED_ENCODING' -Quiet"
  echo "[pre-commit] EncodingCheck: PASSED"
else
  echo "[pre-commit] EncodingCheck: SKIPPED (no encoding-sensitive files staged)"
fi
echo ""
echo ""

pnpm build
pnpm test
