#!/usr/bin/env bash
set -euo pipefail

echo "[pre-commit] Velvet Galaxy checks..."
echo ""

pnpm lint
pnpm typecheck

echo "[pre-commit] Running Supabase security checks..."
pnpm check:supabase-security

echo "[pre-commit] Running encoding checks..."
STAGED_ENCODING=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null | grep -E '\.(sql|md|ps1)' | tr '\n' ',' | sed 's/,$//')
if [ -n "$STAGED_ENCODING" ]; then
  powershell -NoProfile -Command "& ./scripts/check-encoding.ps1 -Files '$STAGED_ENCODING' -Quiet"
  echo "[pre-commit] EncodingCheck: PASSED"
else
  echo "[pre-commit] EncodingCheck: SKIPPED (no encoding-sensitive files staged)"
fi
echo ""

echo "[pre-commit] Running build..."
pnpm build

echo "[pre-commit] Running tests..."
pnpm test

echo "[pre-commit] All checks passed."
